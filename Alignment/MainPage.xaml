<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Alignment.MainPage">

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, *"
          ColumnDefinitions="*,*"
          Padding="20"
          RowSpacing="15"
          ColumnSpacing="15">

        <Label Text="ГОРИЗОНТАЛЬНОЕ"
               Grid.Row="0" Grid.ColumnSpan="2"
               HorizontalOptions="Center"
               FontAttributes="Bold" />

        <Button Text="Start" Grid.Row="1" Grid.Column="0" Clicked="OnHorizontalStart" />
        <Button Text="Center" Grid.Row="1" Grid.Column="1" Clicked="OnHorizontalCenter" />
        <Button Text="End" Grid.Row="2" Grid.Column="0" Clicked="OnHorizontalEnd" />
        <Button Text="Fill" Grid.Row="2" Grid.Column="1" Clicked="OnHorizontalFill" />

        <Label Text="ВЕРТИКАЛЬНОЕ"
               Grid.Row="3" Grid.ColumnSpan="2"
               HorizontalOptions="Center"
               FontAttributes="Bold" />

        <Button Text="Start" Grid.Row="4" Grid.Column="0" Clicked="OnVerticalStart" />
        <Button Text="Center" Grid.Row="4" Grid.Column="1" Clicked="OnVerticalCenter" />
        <Button Text="End" Grid.Row="5" Grid.Column="0" Clicked="OnVerticalEnd" />
        <Button Text="Fill" Grid.Row="5" Grid.Column="1" Clicked="OnVerticalFill" />

        <Border Grid.Row="6" Grid.ColumnSpan="2"
                BackgroundColor="LightGray"
                HeightRequest="200"
                Margin="0,10,0,0">
            <Label x:Name="DemoLabel"
                   Text="Элемент"
                   BackgroundColor="LightBlue"
                   WidthRequest="100"
                   HeightRequest="50"
                   HorizontalOptions="Start"
                   VerticalOptions="Start" />
        </Border>

    </Grid>

</ContentPage>